{
  "title": "SvelteKit App Metrics Prod",
  "uid": "sveltekit-metrics-prod",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["sveltekit"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Memory",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Resident Memory",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"sveltekit-app-prod\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 209715200 },
              { "color": "red", "value": 419430400 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 3,
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"sveltekit-app-prod\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"sveltekit-app-prod\"}",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 4,
      "title": "External Memory",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "nodejs_external_memory_bytes{job=\"sveltekit-app-prod\"}",
          "legendFormat": "External"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 5,
      "title": "SQL Queries",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "id": 6,
      "title": "SQL Duration p95 / p50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(sql_query_duration_seconds_bucket{job=\"sveltekit-app-prod\"}[5m]))",
          "legendFormat": "{{query}} p95"
        },
        {
          "expr": "histogram_quantile(0.5, rate(sql_query_duration_seconds_bucket{job=\"sveltekit-app-prod\"}[5m]))",
          "legendFormat": "{{query}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "title": "SQL Queries / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(sql_query_duration_seconds_count{job=\"sveltekit-app-prod\"}[5m])",
          "legendFormat": "{{query}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["max"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "SSR Render",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 9,
      "title": "SSR Duration p95 / p50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(sveltekit_render_duration_seconds_bucket{job=\"sveltekit-app-prod\"}[5m]))",
          "legendFormat": "{{route}} p95"
        },
        {
          "expr": "histogram_quantile(0.5, rate(sveltekit_render_duration_seconds_bucket{job=\"sveltekit-app-prod\"}[5m]))",
          "legendFormat": "{{route}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "title": "SSR Renders / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "expr": "rate(sveltekit_render_duration_seconds_count{job=\"sveltekit-app-prod\"}[5m])",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["max"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "title": "Runtime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "id": 12,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "nodejs_event_loop_lag_seconds{job=\"sveltekit-app-prod\"}",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 13,
      "title": "Virtual Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "process_virtual_memory_bytes{job=\"sveltekit-app-prod\"}",
          "legendFormat": "Virtual"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ]
}
